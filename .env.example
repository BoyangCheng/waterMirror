NEXT_PUBLIC_LIVE_URL=localhost:3000

# 阶段一：阿里云 PolarDB（PostgreSQL 兼容版）
DATABASE_URL=postgresql://username:password@polardb-endpoint.aliyuncs.com:5432/watermirror_db?sslmode=require

# 阶段二：阿里云 IDaaS OIDC 配置
IDAAS_ISSUER=https://your-instance.aliyunidaas.com/api/v2/
IDAAS_CLIENT_ID=your_client_id
IDAAS_CLIENT_SECRET=your_client_secret
IDAAS_REDIRECT_URI=https://your-domain.com/api/auth/callback
NEXT_PUBLIC_IDAAS_CLIENT_ID=your_client_id
NEXT_PUBLIC_IDAAS_AUTHORIZATION_ENDPOINT=https://your-instance.aliyunidaas.com/oauth2/v2/authorize
AUTH_SECRET=your_random_32_char_secret_here_replace_me

# 阶段三：阿里云 DashScope（通义千问）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL_SMART=qwen-plus
AI_MODEL_FAST=qwen-turbo

# Retell AI（语音面试，保持不变）
RETELL_API_KEY=
