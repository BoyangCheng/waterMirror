# ============================================================
#  WaterMirror — 环境变量模板
#  使用方法：cp .env.example .env  然后填入真实值
#  ⚠️ 真实 .env 已 gitignore，绝不要 commit
# ============================================================

# -------- 站点 URL（影响 OAuth 回调和分享链接）--------
NEXT_PUBLIC_LIVE_URL=https://watermirror.droplets.com.cn
NEXT_PUBLIC_SITE_URL=https://watermirror.droplets.com.cn

# -------- 数据库（PostgreSQL）--------
# 阿里云 PolarDB 兼容 PG，连接串格式：
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=

# -------- Authing 认证（authing.cn）--------
AUTHING_APP_ID=
AUTHING_APP_SECRET=
AUTHING_ISSUER=
# 回调地址必须和 Authing 控制台里配的一致
AUTHING_REDIRECT_URI=https://watermirror.droplets.com.cn/api/auth/callback
NEXT_PUBLIC_AUTHING_APP_HOST=
# 用 openssl rand -base64 32 生成
AUTH_SECRET=

# -------- 阿里云 DashScope（通义千问）--------
DASHSCOPE_API_KEY=
AI_MODEL_SMART=qwen-plus
AI_MODEL_FAST=qwen-turbo

# -------- 火山引擎 RTC --------
VOLCENGINE_RTC_APP_ID=
VOLCENGINE_RTC_APP_KEY=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_KEY=

# -------- 语音识别 ASR（豆包流式 2.0）--------
VOLCENGINE_ASR_APP_ID=
VOLCENGINE_ASR_ACCESS_TOKEN=

# -------- 语音合成 TTS（豆包 seed-tts-2.0）--------
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=

# -------- 阿里云 OSS 文件存储 --------
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_REGION=oss-cn-hangzhou
ALIBABA_OSS_BUCKET=

# -------- Docker 端口绑定 --------
# 默认 docker-compose.yml 绑 127.0.0.1:3000（仅本机），由 nginx 反代访问
# 本地开发想直接外网访问，把 BIND_HOST 改成 0.0.0.0
BIND_HOST=127.0.0.1
HOST_PORT=3000
