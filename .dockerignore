# ============================================================
#  Docker 构建上下文排除规则
#  仅保留构建所需的源码和配置，避免把整个项目塞进 builder
# ============================================================

# 依赖和构建产物（镜像里会重新安装/生成）
node_modules
.next
out
build
dist

# git 和 CI
.git
.github
.gitignore
.gitattributes

# Claude Code 工作区（非常大，不应进入 build context）
.claude

# IDE / OS
.vscode
.idea
.DS_Store
*.swp

# 本地环境变量（绝不进入镜像；通过 --env-file 或 compose env_file 挂载）
.env
.env.local
.env.development
.env.production
.env.*.local

# 日志和临时文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
coverage

# TypeScript 增量构建缓存
*.tsbuildinfo
next-env.d.ts

# 文档和 Markdown（不需要进镜像）
README.md
CONTRIBUTING.md
LICENSE
DEPLOY_UBUNTU.md
DEPLOYMENT_CHECKLIST.md
CLAUDE.md

# 部署脚本（镜像里用不到）
deploy.sh
push.sh
setup-ubuntu.sh
Makefile
scripts/*.bat

# Docker 本身的文件
Dockerfile
docker-compose.yml
.dockerignore

# 测试和快照
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# macOS
.DS_Store

# 数据库迁移文件（如果不需要进镜像）
supabase_schema.sql
